{
  "manifest_version": 3,
  "name": "Recrutas Auto-Fill",
  "version": "1.1.0",
  "description": "AI-powered auto-fill for job application forms using your Recrutas profile",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Recrutas Auto-Fill"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
